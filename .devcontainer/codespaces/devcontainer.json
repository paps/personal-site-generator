{
  "build": {
    "dockerfile": "../Dockerfile"
  },

  // For codespaces, we don't load env vars containing github credentials
  // because we're assuming codespaces already does a great job of loading
  // a temporary access token with the right scope, and that we can use
  // codespaces from a specific github user of our choosing.
  "runArgs": [],

  "postCreateCommand": "bash .devcontainer/setup.sh",

  // Runs a background worker every time the container starts
  "postStartCommand": "nohup bash -c '.devcontainer/bg-worker.sh >/tmp/bg-worker.log 2>&1 &' > /dev/null",

  "customizations": {
    "vscode": {
      "settings": {
        "dev.containers.dockerCredentialHelper": false,
        "dev.containers.copyGitConfig": false,
        // For codespaces, we're assuming it will do the right thing by loading the right git config properly
        //"dev.containers.gitCredentialHelperConfigLocation": "none",
        "dev.containers.mountWaylandSocket": false
      },
      "extensions": [
        "Anthropic.claude-code"
      ]
    }
  }
}
